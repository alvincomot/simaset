// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "mysql"
}

enum Role {
  SUPER_ADMIN
  STAFF
  USER
}

enum KondisiAset {
  BAIK
  RUSAK_RINGAN
  RUSAK_BERAT
}

enum StatusKetersediaan {
  TERSEDIA
  DIPINJAM
  PEMELIHARAAN
}

model user {
  id           Int         @id @default(autoincrement())
  nim          String      @unique @db.VarChar(20)
  namaLengkap  String      @db.VarChar(100)
  password     String      @db.VarChar(255)
  role         Role        @default(USER)
  createdAt    DateTime    @default(now())
  
  // Relasi One-to-Many: 1 User bisa punya banyak transaksi peminjaman
  borrowings   borrowing[]
}

model category {
  id           Int         @id @default(autoincrement())
  namaKategori String      @db.VarChar(50)
  deskripsi    String?     @db.Text // Tanda tanya (?) berarti Nullable
  createdAt    DateTime    @default(now())
  
  // Relasi
  assets       asset[]
}

model location {
  id           Int         @id @default(autoincrement())
  namaLokasi   String      @db.VarChar(50)
  deskripsi    String?     @db.Text
  createdAt    DateTime    @default(now())
  
  // Relasi
  assets       asset[]
}

model asset {
  id                 Int                @id @default(autoincrement())
  kodeAset           String             @unique @db.VarChar(50)
  namaAset           String             @db.VarChar(150)
  categoryId         Int
  locationId         Int
  kondisi            KondisiAset        @default(BAIK)
  statusKetersediaan StatusKetersediaan @default(TERSEDIA)
  createdAt          DateTime           @default(now())

  // Definisi Foreign Key
  category           category           @relation(fields: [categoryId], references: [id])
  location           location           @relation(fields: [locationId], references: [id])
  borrowings         borrowing[]
}

model borrowing {
  id               Int         @id @default(autoincrement())
  userId           Int
  assetId          Int
  tanggalPinjam    DateTime
  tenggatWaktu     DateTime
  tanggalKembali   DateTime?
  statusPeminjaman String      @default("Menunggu") // Bisa juga pakai Enum
  kondisiKembali   KondisiAset?
  catatan          String?     @db.Text
  createdAt        DateTime    @default(now())

  // Definisi Foreign Key
  user             user        @relation(fields: [userId], references: [id])
  asset            asset       @relation(fields: [assetId], references: [id])
}